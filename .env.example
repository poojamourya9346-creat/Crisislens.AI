# =============================================================================
# CrisisLens AI — Root Environment Template
# Copy to .env and adjust values for local development.
# =============================================================================

# --- Application ---
APP_NAME=CrisisLens AI
APP_ENV=development
APP_DEBUG=true

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# --- Frontend ---
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=crisislens
POSTGRES_USER=crisislens
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://crisislens:changeme@postgres:5432/crisislens

# --- Authentication (JWT) ---
JWT_SECRET_KEY=change-this-to-a-secure-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google Cloud / AI (Future Integration) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=asia-south1
GEMINI_API_KEY=
VERTEX_AI_LOCATION=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
