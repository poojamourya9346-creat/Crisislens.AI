# =============================================================================
# CrisisLens AI — Backend Environment Template
# Copy to .env in this directory for local development.
# =============================================================================

APP_NAME=CrisisLens AI
APP_ENV=development
APP_DEBUG=true

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

DATABASE_URL=postgresql+asyncpg://crisislens:changeme@localhost:5432/crisislens

JWT_SECRET_KEY=change-this-to-a-secure-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=asia-south1
GEMINI_API_KEY=
VERTEX_AI_LOCATION=

LOG_LEVEL=INFO
LOG_FORMAT=console

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
